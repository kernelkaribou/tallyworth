# Copy this file to .env and set a strong, random value.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Display currency (ISO code). One of: USD, EUR, GBP, JPY, CNY, CAD, AUD,
# CHF, INR, KRW, BRL, MXN, SEK, NZD, ZAR. Unknown codes fall back to USD.
DEFAULT_CURRENCY=USD

# Optional: a raw symbol override for a currency not in the list above.
# When set, this takes precedence over DEFAULT_CURRENCY.
# CURRENCY_SYMBOL=
